{
  "name": "@orgtrace/cli",
  "version": "0.1.0",
  "description": "Command-line shell for OrgTrace local dependency analysis",
  "private": true,
  "bin": {
    "orgtrace": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@orgtrace/core": "workspace:*",
    "@orgtrace/scanner": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^5.0.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
